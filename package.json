{
  "name": "travel-tracker",
  "version": "1.0.0",
  "description": "Map out your travels and share on social media",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "postinstall": "mkdir -p public/geo && cp node_modules/world-atlas/countries-110m.json public/geo/ && cp node_modules/us-atlas/states-10m.json public/geo/"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.0",
    "html-to-image": "^1.11.11",
    "next": "^15.5.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-simple-maps": "^3.0.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-simple-maps": "^3.0.6",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.51.0"
  }
}
